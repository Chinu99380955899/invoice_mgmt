VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_APP_NAME=Invoice Automation
VITE_PORT=5173

# Dev-only: when true, all API calls are served by src/services/mockServer.js
# so the whole UI can be demoed without the backend running.
# Leave false / unset to hit the real backend.
VITE_USE_MOCK_API=false
